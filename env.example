# ===================================================
#  .env.example — Все переменные окружения проекта
#
#  Скопируй этот файл, заполни значения и добавь
#  в Vercel: Settings → Environment Variables
#
#  ВАЖНО: .env никогда не коммитится в git!
#  Этот файл (.env.example) — только шаблон.
# ===================================================


# ── Firebase (публичные ключи для фронта) ──────────
# Берёшь из Firebase Console → Project Settings → Your apps

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=


# ── Firebase Admin (серверные, секретные!) ──────────
# Берёшь из Firebase Console → Project Settings → Service accounts
# → Generate new private key

FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=


# ── Telegram Bot ────────────────────────────────────
# Получаешь у @BotFather при создании бота

BOT_TOKEN=


# ── Cloudinary ──────────────────────────────────────
# Берёшь из Cloudinary Dashboard

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=


# ── Admin-панель ────────────────────────────────────
# ADMIN_PASSWORD_HASH — bcrypt-хэш пароля (cost 12)
# Генерируй через: node -e "require('bcryptjs').hash('твойпароль',12).then(console.log)"
#
# JWT_SECRET — случайная строка, например:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

ADMIN_PASSWORD_HASH=
JWT_SECRET=


# ── Cron-защита ─────────────────────────────────────
# Любая случайная строка — защищает /api/notify от внешних вызовов
# node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"

CRON_SECRET=


# ── Настройки приложения ─────────────────────────────
# Меняй здесь — код трогать не нужно
# Для dev можно поставить другие имена, например: ТЕСТ1,ТЕСТ2,ТЕСТ3

CHEFS=ТЕСТ1,ТЕСТ2,ТЕСТ3
VOTE_THRESHOLD=2
PLAN_AHEAD_DAYS=7
